{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TechnicalPlan",
  "description": "Canonical output schema for the tech-plan skill. All downstream agents consume this artifact.",

  "oneOf": [
    { "$ref": "#/definitions/CompletePlan" },
    { "$ref": "#/definitions/FailurePlan" }
  ],

  "definitions": {

    "CompletePlan": {
      "type": "object",
      "required": [
        "schema_version", "status", "project_name", "project_type",
        "summary", "stack", "constraints", "assumptions",
        "architecture_decisions", "existing_system_impact",
        "cross_cutting_checklist", "traceability",
        "phases", "external_dependencies", "risks",
        "open_questions", "execution_handoff"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0" },
        "status": { "type": "string", "const": "complete" },
        "project_name": { "type": "string" },
        "project_type": {
          "type": "string",
          "enum": ["greenfield", "feature_extension", "refactor", "migration", "integration"]
        },
        "summary": { "type": "string" },

        "stack": {
          "type": "object",
          "required": ["frontend", "backend", "database", "auth", "hosting", "key_libraries"],
          "properties": {
            "frontend": { "type": "string" },
            "backend": { "type": "string" },
            "database": { "type": "string" },
            "auth": { "type": "string" },
            "hosting": { "type": "string" },
            "key_libraries": {
              "type": "array",
              "items": { "type": "string" }
            },
            "stack_is_recommendation": {
              "type": "boolean",
              "description": "True if stack was not specified in requirements and was recommended by this skill"
            }
          }
        },

        "constraints": {
          "type": "array",
          "items": { "type": "string" }
        },

        "assumptions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["assumption", "confidence", "impact_if_wrong"],
            "properties": {
              "assumption": { "type": "string" },
              "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
              "impact_if_wrong": { "type": "string" }
            }
          }
        },

        "architecture_decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["decision", "choice", "rationale", "trade_off"],
            "properties": {
              "decision": { "type": "string" },
              "choice": { "type": "string" },
              "rationale": { "type": "string" },
              "trade_off": { "type": "string" }
            }
          }
        },

        "existing_system_impact": {
          "description": "null for greenfield projects. Required object for all other project types.",
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": [
                "affected_components",
                "backward_compatibility_required",
                "migration_needed",
                "rollback_constraints"
              ],
              "properties": {
                "affected_components": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "backward_compatibility_required": { "type": "boolean" },
                "backward_compatibility_notes": { "type": "string" },
                "migration_needed": { "type": "boolean" },
                "migration_strategy": { "type": "string" },
                "api_contracts_to_preserve": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "data_backfill_required": { "type": "boolean" },
                "data_backfill_notes": { "type": "string" },
                "deprecation_path": { "type": "string" },
                "rollback_constraints": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          ]
        },

        "cross_cutting_checklist": {
          "type": "object",
          "required": [
            "auth_security", "observability_logging", "test_strategy",
            "ci_cd", "rollback_release", "data_migration",
            "performance_scalability", "feature_flags",
            "monitoring_alerts", "analytics_telemetry"
          ],
          "properties": {
            "auth_security":           { "$ref": "#/definitions/CrossCuttingStatus" },
            "observability_logging":   { "$ref": "#/definitions/CrossCuttingStatus" },
            "test_strategy":           { "$ref": "#/definitions/CrossCuttingStatus" },
            "ci_cd":                   { "$ref": "#/definitions/CrossCuttingStatus" },
            "rollback_release":        { "$ref": "#/definitions/CrossCuttingStatus" },
            "data_migration":          { "$ref": "#/definitions/CrossCuttingStatus" },
            "performance_scalability": { "$ref": "#/definitions/CrossCuttingStatus" },
            "feature_flags":           { "$ref": "#/definitions/CrossCuttingStatus" },
            "monitoring_alerts":       { "$ref": "#/definitions/CrossCuttingStatus" },
            "analytics_telemetry":     { "$ref": "#/definitions/CrossCuttingStatus" }
          }
        },

        "traceability": {
          "type": "array",
          "description": "Every must-have story must appear here. No story may be silently dropped.",
          "items": {
            "type": "object",
            "required": ["story_id", "story_title", "covered_in_phase", "deliverable_ids"],
            "properties": {
              "story_id": { "type": "string" },
              "story_title": { "type": "string" },
              "covered_in_phase": { "type": "string" },
              "deliverable_ids": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },

        "phases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "name", "goal", "depends_on", "workstreams", "definition_of_done"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "goal": { "type": "string" },
              "depends_on": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Phase ids this phase depends on. Empty array for Phase 1."
              },
              "workstreams": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["id", "name", "parallel_with", "deliverables"],
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "parallel_with": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Workstream ids this can run in parallel with. Empty if sequential."
                    },
                    "deliverables": {
                      "type": "array",
                      "minItems": 1,
                      "items": { "$ref": "#/definitions/Deliverable" }
                    }
                  }
                }
              },
              "definition_of_done": {
                "type": "array",
                "minItems": 2,
                "items": { "type": "string" },
                "description": "Specific, verifiable conditions. All must be true before next phase begins."
              }
            }
          }
        },

        "external_dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "required_by_phase", "blocking", "owner", "unblocking_path"],
            "properties": {
              "name": { "type": "string" },
              "required_by_phase": { "type": "string" },
              "blocking": { "type": "boolean" },
              "owner": { "type": "string" },
              "unblocking_path": { "type": "string" }
            }
          }
        },

        "risks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["risk", "phase_affected", "likelihood", "impact", "mitigation"],
            "properties": {
              "risk": { "type": "string" },
              "phase_affected": { "type": "string" },
              "likelihood": { "type": "string", "enum": ["low", "medium", "high"] },
              "impact": { "type": "string", "enum": ["low", "medium", "high"] },
              "mitigation": { "type": "string" }
            }
          }
        },

        "open_questions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["question", "blocking_phase", "owner"],
            "properties": {
              "question": { "type": "string" },
              "blocking_phase": { "type": "string" },
              "owner": { "type": "string" }
            }
          }
        },

        "execution_handoff": {
          "type": "object",
          "description": "Structured input consumed directly by the Execution skill.",
          "required": [
            "project_name", "stack", "first_phase_id",
            "phases_summary", "external_dependencies",
            "risk_flags", "open_questions"
          ],
          "properties": {
            "project_name": { "type": "string" },
            "stack": { "type": "object" },
            "first_phase_id": { "type": "string" },
            "phases_summary": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "name", "depends_on", "workstream_count", "deliverable_count"],
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "depends_on": { "type": "array", "items": { "type": "string" } },
                  "workstream_count": { "type": "integer" },
                  "deliverable_count": { "type": "integer" }
                }
              }
            },
            "external_dependencies": {
              "type": "array",
              "items": { "type": "string" }
            },
            "risk_flags": {
              "type": "array",
              "items": { "type": "string" }
            },
            "open_questions": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },

    "FailurePlan": {
      "type": "object",
      "description": "Emitted when planning cannot proceed safely due to missing critical information.",
      "required": ["schema_version", "status", "blocking_reasons", "required_inputs", "recommended_owner"],
      "properties": {
        "schema_version": { "type": "string", "const": "1.0" },
        "status": { "type": "string", "const": "blocked" },
        "blocking_reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommended_owner": { "type": "string" },
        "partial_plan": {
          "description": "Optional partial output if some planning was possible before blocking.",
          "oneOf": [{ "type": "null" }, { "type": "object" }]
        }
      }
    },

    "Deliverable": {
      "type": "object",
      "required": ["id", "description", "story_refs", "acceptance_criteria"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Format: phase-workstream-sequence. e.g. 1.A.1, 2.B.3"
        },
        "description": {
          "type": "string",
          "description": "A specific thing that exists when done. Not an action — a result."
        },
        "story_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Story IDs from technical-requirements that this deliverable implements."
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string" },
          "description": "Specific, independently verifiable conditions. Used by QA and Execution agents."
        }
      }
    },

    "CrossCuttingStatus": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["included", "not_needed", "deferred"]
        },
        "notes": {
          "type": "string",
          "description": "Required if status is deferred — explain when and how it will be addressed."
        },
        "phase": {
          "type": "string",
          "description": "Phase id where this concern is addressed. Required if status is included."
        }
      }
    }

  }
}
